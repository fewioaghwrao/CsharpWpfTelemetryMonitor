<Window x:Class="WpfApp.Views.ConfirmExitDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="終了確認" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        Background="LightGray"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Message}" Background="Transparent" Foreground="Black"
                   TextWrapping="Wrap" FontSize="14" />

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" >
            <Button Content="終了" Width="100" Margin="0,0,8,0" FontSize="14" Background="White"
                    IsDefault="True" Click="OnOk"/>
            <Button Content="キャンセル" Width="100" Margin="0,0,8,0" FontSize="14" Background="White"
                    IsCancel="True" Click="OnCancel"/>
        </StackPanel>
    </Grid>
</Window>
