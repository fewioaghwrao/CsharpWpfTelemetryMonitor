<Window x:Class="WpfApp.Views.SettingsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="LightGray"
        Title="設定" Height="360" Width="430">
    <Grid Margin="16">
        <!-- RowDefinitions は属性ではなく要素で記述する -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Spacing は使えないので子に Margin -->
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="警告閾値" VerticalAlignment="Center" FontSize="14"/>
            <TextBox Width="100" Text="{Binding AlertThreshold, UpdateSourceTrigger=PropertyChanged}"
                     MaxLength="2" InputMethod.IsInputMethodEnabled="False"
                     PreviewTextInput="AlertThresholdTextBox_PreviewTextInput" FontSize="14"
                     Margin="8,0,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
            <TextBlock Text="サンプリング周期 (ms)" VerticalAlignment="Center" FontSize="14"/>
            <TextBox Width="100" Text="{Binding SampleIntervalMs, UpdateSourceTrigger=PropertyChanged}"
                     PreviewTextInput="AlertThresholdTextBox_PreviewTextInput"
                     FontSize="14"
                     Margin="8,0,0,0" MaxLength="4" InputMethod.IsInputMethodEnabled="False"/>
        </StackPanel>
        <GroupBox Grid.Row="2" Header="音声設定" Margin="0,12,0,12">
            <StackPanel Margin="8,6,8,8">
                <CheckBox Content="音声を有効にする" 
                  IsChecked="{Binding IsVoiceEnabled, Mode=TwoWay}" Visibility="Collapsed"/>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0" Visibility="Collapsed">
                    <TextBlock Text="音声" Width="80" VerticalAlignment="Center"/>
                    <ComboBox Width="220"
                      ItemsSource="{Binding InstalledVoices}"
                      SelectedItem="{Binding SelectedVoice, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="速度" Width="80" VerticalAlignment="Center"/>
                    <!-- -10 ～ 10 -->
                    <Slider Width="220" Minimum="-10" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True"
                    Value="{Binding VoiceRate, Mode=TwoWay}" />
                    <TextBlock Text="{Binding VoiceRate}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="音量" Width="80" VerticalAlignment="Center"/>
                    <!-- 0 ～ 100 -->
                    <Slider Width="220" Minimum="0" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True"
                    Value="{Binding VoiceVolume, Mode=TwoWay}" />
                    <TextBlock Text="{Binding VoiceVolume}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="テスト読み上げ"
            Width="120" Height="32" Background="White"
            Command="{Binding TestSpeakCommand}"
            IsEnabled="{Binding IsVoiceEnabled}"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" IsDefault="True" Command="{Binding SaveCommand}" Margin="0,0,8,0" Background="white" FontSize="14"/>
            <Button Content="Cancel" Width="80" IsCancel="True" Margin="0,0,8,0" Background="white" FontSize="14"/>
        </StackPanel>
        
    </Grid>
</Window>
