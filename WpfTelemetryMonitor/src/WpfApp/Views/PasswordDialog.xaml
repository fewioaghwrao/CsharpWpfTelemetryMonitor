<Window x:Class="WpfApp.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="パスワード確認"
        SizeToContent="WidthAndHeight"
        MinWidth="440"
        Background="#F3F4F6"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.92"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.84"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F9FAFB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InputTextStyle" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="InputPasswordStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Border Margin="20"
            Padding="24"
            Background="White"
            BorderBrush="#E5E7EB"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- タイトル -->
            <StackPanel>
                <TextBlock Text="パスワード確認"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#111827"/>
                <TextBlock Text="ログクリアを実行するには認証が必要です。"
                           Margin="0,6,0,0"
                           FontSize="13"
                           Foreground="#6B7280"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- 入力欄 -->
            <StackPanel Grid.Row="2">
                <TextBlock Text="パスワード（ddHH）"
                           Margin="0,0,0,6"
                           FontSize="13"
                           Foreground="#374151"/>

                <Grid Width="240">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>

                    <!-- 非表示時 -->
                    <PasswordBox x:Name="Pwd"
                                 Grid.Column="0"
                                 Style="{StaticResource InputPasswordStyle}"
                                 PasswordChanged="Pwd_PasswordChanged"/>

                    <!-- 表示時 -->
                    <TextBox x:Name="PwdVisible"
                             Grid.Column="0"
                             Style="{StaticResource InputTextStyle}"
                             Visibility="Collapsed"
                             TextChanged="PwdVisible_TextChanged"/>

                    <!-- 表示/非表示 -->
                    <ToggleButton x:Name="TogglePasswordButton"
              Grid.Column="1"
              Margin="8,0,0,0"
              Width="52"
              Height="32"
              VerticalAlignment="Center"
              HorizontalAlignment="Center"
              Checked="TogglePasswordButton_Checked"
              Unchecked="TogglePasswordButton_Unchecked"
              Background="White"
              BorderBrush="#D1D5DB"
              ToolTip="パスワードを表示">
                        <TextBlock x:Name="TogglePasswordText"
               Text="表示"
               FontSize="11"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>
                    </ToggleButton>
                </Grid>
            </StackPanel>

            <TextBlock Grid.Row="4"
                       Text="必要な場合のみ表示してください。"
                       FontSize="12"
                       Foreground="#6B7280"/>

            <!-- ボタン -->
            <StackPanel Grid.Row="6"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="OK"
                        Style="{StaticResource PrimaryButtonStyle}"
                        IsDefault="True"
                        Click="OnOk"/>
                <Button Content="キャンセル"
                        Style="{StaticResource SecondaryButtonStyle}"
                        IsCancel="True"
                        Click="OnCancel"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
