<Window x:Class="WpfApp.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="パスワード確認" SizeToContent="WidthAndHeight"
        Background="LightGray"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <TextBlock Text="パスワード（ddHH）:" VerticalAlignment="Center" FontSize="14"/>
            <PasswordBox x:Name="Pwd" Width="120" Margin="8,0,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="0,0,8,0" IsDefault="True" Click="OnOk" FontSize="14" Background="White"/>
            <Button Content="キャンセル" Width="80" Margin="0,0,8,0" IsCancel="True" FontSize="14" Background="White"/>
        </StackPanel>
    </Grid>
</Window>

